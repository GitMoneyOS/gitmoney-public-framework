# Everything that passed the asset test and awaits owner approval.
filters:
  and:
    - 'status == "ready-to-promote"'
properties:
  promotion-target:
    displayName: Target
  classification:
    displayName: Classification
views:
  - type: table
    name: Awaiting approval
    order:
      - file.name
      - promotion-target
      - classification
      - owner
      - created
